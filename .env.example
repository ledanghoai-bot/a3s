APP_ENV=development

# Meta / Facebook Messenger
META_VERIFY_TOKEN=
META_APP_SECRET=
PAGE_ACCESS_TOKEN=

# Ha tang
DATABASE_URL=postgresql+asyncpg://alpha3s:alpha3s@db:5432/alpha3s
REDIS_URL=redis://redis:6379/0

# LLM (DeepSeek - OpenAI-compatible)
LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat

# Embedding: chay local, khong can API key
EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2
EMBEDDING_DIM=384

# Human handoff (issue #7)
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=
ADMIN_API_TOKEN=

# Dashboard Next.js (issue #8)
DASHBOARD_CORS_ORIGINS=http://localhost:3000

# Kenh khach hang du phong qua Telegram (bot RIENG, khac TELEGRAM_BOT_TOKEN o tren)
TELEGRAM_CUSTOMER_BOT_TOKEN=
