APP_ENV=development

# Meta / Facebook Messenger
META_VERIFY_TOKEN=
META_APP_SECRET=
PAGE_ACCESS_TOKEN=

# Ha tang
DATABASE_URL=postgresql+asyncpg://alpha3s:alpha3s@db:5432/alpha3s
REDIS_URL=redis://redis:6379/0

# LLM (DeepSeek - OpenAI-compatible)
LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat

# Embedding: chay local, khong can API key
EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2
EMBEDDING_DIM=384

# Human handoff (issue #7)
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=
# ADMIN_API_TOKEN: DA XOA (issue #9, Bat 1) - thay the boi dang nhap that
# (staff_users/staff_sessions, issue #8 Bat 4). Tao tai khoan dau tien bang:
#   docker compose exec api python scripts/create_staff_user.py <user> <pass> "<ten>"

# Dashboard Next.js (issue #8)
DASHBOARD_CORS_ORIGINS=http://localhost:3000

# Kenh khach hang du phong qua Telegram (bot RIENG, khac TELEGRAM_BOT_TOKEN o tren)
TELEGRAM_CUSTOMER_BOT_TOKEN=

# Lop NLU (issue #12) - feature flag, mac dinh tat (false). Bat = true de thu
# nghiem NLU Router bo sung hint cho LLM - xem ISSUES-VI.md #12.
ENABLE_NLU_ROUTER=false
